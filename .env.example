# DocsRAG environment variables.
# Copy to .env for local dev (already gitignored). In production set these in
# the Render dashboard. NEVER commit real secrets.

# --- Required ---------------------------------------------------------------
# Supabase: use the service-role key (server-side only, bypasses RLS).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# Groq API key (free at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key

# --- Optional: one-shot auto-migration --------------------------------------
# If set, the app runs db/schema.sql on startup (tables + match_chunks pgvector
# RPC + HNSW index) so deployment is fully one-shot. Use the Supabase DIRECT
# connection string (Settings → Database → Connection string → URI). Without it
# the app still works via an in-Python cosine fallback, but run db/schema.sql by
# hand for the indexed RPC path.
# DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# --- Models (optional; defaults shown) --------------------------------------
# 8B is primary for longevity (500K tokens/day on Groq free); 70B is the
# user-selectable "Best" model and the cross-fallback target.
# PRIMARY_MODEL=llama-3.1-8b-instant
# FALLBACK_MODEL=llama-3.3-70b-versatile

# --- Retrieval (optional; tuned for bge-small) ------------------------------
# STRONG_THRESHOLD=0.55
# WEAK_THRESHOLD=0.45
# TOP_K=5
# CHUNK_TOKENS=500
# CHUNK_OVERLAP=80
# MAX_HISTORY_TURNS=6

# --- Limits (optional) ------------------------------------------------------
# PER_IP_DAILY_LIMIT=10
# TOKEN_BUDGET_PRIMARY=450000      # keep under 8B's 500K TPD
# TOKEN_BUDGET_FALLBACK=90000      # keep under 70B's 100K TPD
# MAX_UPLOAD_MB=10
# MAX_PAGES=100

# --- Set automatically in Docker; leave unset for local dev -----------------
# STATIC_DIR=/app/frontend/dist
# EMBEDDING_CACHE_DIR=/app/models
